{"root":{"data":{"id":"dhv8d40f1qo0","created":1776408798433,"text":"Redis"},"children":[{"data":{"id":"dhv8ejeede00","created":1776408910294,"text":"Redis特点","layout_right_offset":{"x":-30,"y":-83}},"children":[{"data":{"id":"dhv8qn2v9bs0","created":1776409858674,"text":"纯内存操作，定期异步flush到硬盘保存","layout_right_offset":{"x":9,"y":-47},"background":"#ffffff"},"children":[]},{"data":{"id":"dhv8rmvug680","created":1776409936613,"text":"读写速度极快","layout_right_offset":{"x":15,"y":-49}},"children":[]},{"data":{"id":"dhv8rxk0pb40","created":1776409959843,"text":"支持数据持久化 AOF和RDB","layout_right_offset":{"x":18,"y":-55}},"children":[]}]},{"data":{"id":"dhv8qamk4740","created":1776409831567,"text":"Redis为什么这么快","layout_right_offset":{"x":-30,"y":-148}},"children":[{"data":{"id":"dhv8zdolpt40","created":1776410543498,"text":"纯内存操作，避免磁盘IO开销"},"children":[]},{"data":{"id":"dhv8zniwwww0","created":1776410564921,"text":"单线程的多路复用IO网络模型"},"children":[]},{"data":{"id":"dhv8zuy89t40","created":1776410581085,"text":"使用VM(虚拟内存)机制将冷数据保存到磁盘"},"children":[]}]},{"data":{"id":"dhv9u3kr11c0","created":1776412950786,"text":"Redis持久化机制","layout_right_offset":{"x":-29,"y":-157}},"children":[{"data":{"id":"dhv9ua7mag80","created":1776412965229,"text":"AOF"},"children":[{"data":{"id":"dhv9ug10cn40","created":1776412977890,"text":"记录写操作命令到日志，恢复时执行写操作"},"children":[{"data":{"id":"dhva1dprxrk0","created":1776413521407,"text":"性能较差但数据完整性比较好"},"children":[]}]}]},{"data":{"id":"dhv9ud13c280","created":1776412971365,"text":"RDB"},"children":[{"data":{"id":"dhv9urrxl6o0","created":1776413003463,"text":"保存指定时间间隔的内存数据快照到磁盘，恢复时将磁盘数据读到内存"},"children":[{"data":{"id":"dhva1ii9qzk0","created":1776413531837,"text":"恢复速度快但数据完整性比较差"},"children":[]}]}]},{"data":{"id":"dhva2kixbqg0","created":1776413614594,"text":"混合持久化"},"children":[{"data":{"id":"dhva2nu0pm80","created":1776413621795,"text":"RDB全量数据+AOF增量数据"},"children":[]}]}]},{"data":{"id":"dhvaaajevew0","created":1776414219769,"text":"过期键删除策略","layout_right_offset":{"x":-8,"y":-173}},"children":[{"data":{"id":"dhvaafufkcw0","created":1776414231320,"text":"定时删除","expandState":"expand"},"children":[{"data":{"id":"dhvaakn06740","created":1776414241754,"text":"创建定时任务，键到期即删除"},"children":[{"data":{"id":"dhvab0y8ftc0","created":1776414277262,"text":"优点：内存友好，及时淘汰过期键"},"children":[]},{"data":{"id":"dhvabduj4oo0","created":1776414305336,"text":"缺点：cpu不友好，删除操作占用cpu时间，影响服务响应和RT"},"children":[]}]}]},{"data":{"id":"dhvabobyq1s0","created":1776414328158,"text":"惰性删除"},"children":[{"data":{"id":"dhvabrse7tk0","created":1776414335682,"text":"查询键时看是否过期，过期即删"},"children":[{"data":{"id":"dhvac0bx3bs0","created":1776414354277,"text":"优点：cpu友好，只检查使用到的键是否过期"},"children":[]},{"data":{"id":"dhvac6291g80","created":1776414366753,"text":"缺点：内存不友好，过期键一直未使用就一直保存在内存里，造成内存泄漏"},"children":[]}]}]},{"data":{"id":"dhvacjk1ce00","created":1776414396126,"text":"定期删除"},"children":[{"data":{"id":"dhvaco9494g0","created":1776414406350,"text":"定期检查键是否过期"},"children":[]}]}]},{"data":{"id":"dhvafwtmbw80","created":1776414660096,"text":"内存淘汰策略","note":"Redis内存超过最大内存设置后，会启用内存淘汰策略删除不常用的数据","layout_right_offset":{"x":6,"y":-152}},"children":[]},{"data":{"id":"dhvb54vxx1c0","created":1776416636755,"text":"缓存与数据库双写数据一致性","priority":null,"progress":1,"layout_right_offset":{"x":-3,"y":-185}},"children":[{"data":{"id":"dhvbrfhe06g0","created":1776418383831,"text":"先更新数据库，再更新缓存"},"children":[]},{"data":{"id":"dhvbrlagjj40","created":1776418396473,"text":"先更新缓存，再更新数据库"},"children":[]},{"data":{"id":"dhvbrphnenk0","created":1776418405615,"text":"先更新数据库，再删除缓存"},"children":[]},{"data":{"id":"dhvbrxgkiy00","created":1776418422964,"text":"先删除缓存，再更新数据库"},"children":[]}]},{"data":{"id":"dhxn17vzz340","created":1776653303064,"text":"缓存问题","layout_right_offset":{"x":36,"y":-199}},"children":[{"data":{"id":"dhxn1gdqi3c0","created":1776653321551,"text":"缓存雪崩","note":"1.同一时刻大量缓存key失效，大量请求打在数据库上，造成数据库宕机\n2.Redis宕机"},"children":[{"data":{"id":"dhxn60j0xi00","created":1776653678863,"text":"设置缓存key随机过期时间"},"children":[]},{"data":{"id":"dhxn6coxfzk0","created":1776653705342,"text":"Redis主从+哨兵模式，保障集群高可用"},"children":[]}]},{"data":{"id":"dhxn1jy5qco0","created":1776653329316,"text":"缓存穿透","note":"请求数据在缓存和数据库中都不存在"},"children":[{"data":{"id":"dhxofxz45eo0","created":1776657278057,"text":"布隆过滤器","progress":1},"children":[]}]},{"data":{"id":"dhxn1n7gw9s0","created":1776653336410,"text":"缓存击穿","note":"热点key过期，造成数据库访问压力大"},"children":[{"data":{"id":"dhxn8s7m6i00","created":1776653895852,"text":"设置热点key永不过期"},"children":[]}]},{"data":{"id":"dhxr636ghyw0","created":1776664969073,"text":"缓存预热"},"children":[]},{"data":{"id":"dhxr67jeabk0","created":1776664978563,"text":"缓存降级"},"children":[]}]},{"data":{"id":"dhxs8pbxdgw0","created":1776667995132,"text":"线程模型","layout_right_offset":{"x":33,"y":-215}},"children":[{"data":{"id":"dhxs8vk2i280","created":1776668008685,"text":"为什么采用单线程"},"children":[{"data":{"id":"dhxsa5m1gcw0","created":1776668108936,"text":"Redis是纯内存操作，cpu开销非性能瓶颈，网路IO即客户端和服务端的网络传输延迟才是系统性能瓶颈"},"children":[]}]},{"data":{"id":"dhxs9tv4q740","created":1776668083364,"text":"单线程优势"},"children":[{"data":{"id":"dhxsc7g4ouw0","created":1776668269660,"text":"1.避免线程切换的上下文开销；2.不用引用锁，避免同步机制开销"},"children":[]}]},{"data":{"id":"dhxsr5mdcgo0","created":1776669441147,"text":"真的是单线程吗"},"children":[{"data":{"id":"dhxsraozqvc0","created":1776669452189,"text":"Redis 6.0之前是单线程，6.0之后引用多线程IO处理网络数据读写和协议解析，执行命令依旧是单线程"},"children":[]}]},{"data":{"id":"dhxstfgvskg0","created":1776669619311,"text":"线程模型","progress":1},"children":[]}]},{"data":{"id":"dhxt2o0mcs80","created":1776670343196,"text":"事务","note":"Redis单个命令执行是原子性的，但事务的执行是不具备原子性的；如果事务中某条命令执行失败，前面的命令不会回滚，后面的命令会继续执行","layout_right_offset":{"x":38,"y":-212}},"children":[]},{"data":{"id":"dhxtg74n8340","created":1776671403532,"text":"部署方式","layout_right_offset":{"x":40,"y":-238}},"children":[{"data":{"id":"dhxtggytmp40","created":1776671424948,"text":"单机模式","note":"单节点，无备用节点"},"children":[]},{"data":{"id":"dhxtghp1nso0","created":1776671426534,"text":"主从模式","note":"主从实例间实时数据同步"},"children":[]},{"data":{"id":"dhxtgu1anzs0","created":1776671453396,"text":"哨兵模式","note":"1 master + n slave + n sentinel "},"children":[]},{"data":{"id":"dhxtgzqems80","created":1776671465798,"text":"Cluster集群模式","note":"将键哈希映射到虚拟槽slot，每个节点存储部分slot，实现分布式存储"},"children":[]}]}]},"template":"right","theme":"fresh-pink","version":"1.4.43"}