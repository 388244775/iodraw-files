{"root":{"data":{"id":"dhv8d40f1qo0","created":1776408798433,"text":"Redis"},"children":[{"data":{"id":"dhv8ejeede00","created":1776408910294,"text":"Redis特点","layout_right_offset":{"x":-30,"y":-83}},"children":[{"data":{"id":"dhv8qn2v9bs0","created":1776409858674,"text":"纯内存操作，定期异步flush到硬盘保存","layout_right_offset":{"x":9,"y":-47},"background":"#ffffff"},"children":[]},{"data":{"id":"dhv8rmvug680","created":1776409936613,"text":"读写速度极快","layout_right_offset":{"x":15,"y":-49}},"children":[]},{"data":{"id":"dhv8rxk0pb40","created":1776409959843,"text":"支持数据持久化 AOF和RDB","layout_right_offset":{"x":18,"y":-55}},"children":[]}]},{"data":{"id":"dhv8qamk4740","created":1776409831567,"text":"Redis为什么这么快","layout_right_offset":{"x":-32,"y":-122}},"children":[{"data":{"id":"dhv8zdolpt40","created":1776410543498,"text":"纯内存操作，避免磁盘IO开销"},"children":[]},{"data":{"id":"dhv8zniwwww0","created":1776410564921,"text":"单线程的多路复用IO网络模型"},"children":[]},{"data":{"id":"dhv8zuy89t40","created":1776410581085,"text":"使用VM(虚拟内存)机制将冷数据保存到磁盘"},"children":[]}]},{"data":{"id":"dhv9u3kr11c0","created":1776412950786,"text":"Redis持久化机制","layout_right_offset":{"x":-34,"y":-109}},"children":[{"data":{"id":"dhv9ua7mag80","created":1776412965229,"text":"AOF"},"children":[{"data":{"id":"dhv9ug10cn40","created":1776412977890,"text":"记录写操作命令到日志，恢复时执行写操作"},"children":[{"data":{"id":"dhva1dprxrk0","created":1776413521407,"text":"性能较差但数据完整性比较好"},"children":[]}]}]},{"data":{"id":"dhv9ud13c280","created":1776412971365,"text":"RDB"},"children":[{"data":{"id":"dhv9urrxl6o0","created":1776413003463,"text":"保存指定时间间隔的内存数据快照到磁盘，恢复时将磁盘数据读到内存"},"children":[{"data":{"id":"dhva1ii9qzk0","created":1776413531837,"text":"恢复速度快但数据完整性比较差"},"children":[]}]}]},{"data":{"id":"dhva2kixbqg0","created":1776413614594,"text":"混合持久化"},"children":[{"data":{"id":"dhva2nu0pm80","created":1776413621795,"text":"RDB全量数据+AOF增量数据"},"children":[]}]}]},{"data":{"id":"dhvaaajevew0","created":1776414219769,"text":"过期键删除策略"},"children":[{"data":{"i